# Server
HOST=0.0.0.0
PORT=8000

# Upload limits
MAX_FILE_SIZE_MB=10

# Comma-separated list of allowed language codes (eng, vie, jpn)
SUPPORTED_LANGUAGES=eng,vie,jpn

# Optional: override EasyOCR model storage directory
# EASYOCR_MODEL_DIR=/path/to/models  (default: ~/.EasyOCR/model)

# Debug: save intermediate pipeline images for review (true/false)
DEBUG_SAVE_IMAGES=false
DEBUG_OUTPUT_DIR=debug_output
